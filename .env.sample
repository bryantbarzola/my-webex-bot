# === WEBEX BOT CONFIG ===
BOT_TOKEN=your-webex-bot-token-here

# === AI PROVIDER CONFIG ===
# Options: openai, claude
AI_PROVIDER=openai

# Your AI API key (from whichever provider you're using)
AI_API_KEY=your-ai-api-key-here

# === ADVANCED: ROOM RESTRICTION (bot-advanced.py only) ===
# Leave blank to allow all rooms, or add room IDs to restrict.
# Use the "room info" bot command to get a room ID.
# Multiple rooms: separate with commas (no spaces)
ALLOWED_ROOMS=
