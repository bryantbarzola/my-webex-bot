# === WEBEX BOT CONFIG ===
BOT_TOKEN=your-webex-bot-token-here

# === AI PROVIDER CONFIG ===
# Uncomment ONE provider below:
AI_PROVIDER=bedrock
#AI_PROVIDER=openai
#AI_PROVIDER=claude

# AI model (leave blank to use the default for your provider)
# Bedrock default:  us.anthropic.claude-haiku-4-5-20251001-v1:0
# OpenAI default:   gpt-4o
# Claude default:   claude-sonnet-4-6-20250514
AI_MODEL=

# Your AI API key (for openai or claude providers)
AI_API_KEY=

# === AWS BEDROCK CONFIG (only needed if AI_PROVIDER=bedrock) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# === ROOM RESTRICTION ===
# Leave blank to allow all rooms, or add room IDs to restrict.
# Use the "room info" bot command to get a room ID.
# Multiple rooms: separate with commas (no spaces)
ALLOWED_ROOMS=
